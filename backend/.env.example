# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_20251106_analysis_a
DB_USER=postgres
DB_PASSWORD=replace-with-your-database-password

# API配置
API_PORT=8000
DEBUG=True

# 安全配置
# 本地首次配置可运行:
# uv run python scripts/generate_security_secrets.py
JWT_SECRET_KEY=replace-with-random-32-bytes-or-longer
MASTER_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
INTERNAL_GATEWAY_SECRET=replace-with-random-32-bytes-or-longer
LOGIN_PUBLIC_KEY_ID=login-rsa-local-001
LOGIN_PRIVATE_KEY=replace-with-pem-private-key-escaped-newlines
REQUIRE_SECURE_LOGIN=true
ALLOW_INSECURE_DEV_KEYS=false

# 实验功能：运行态安全材料外部化
# memory: 默认单进程内存；diskcache: 本机多 worker 共享实验后端
EXPERIMENTAL_RUNTIME_STATE_BACKEND=memory
RUNTIME_STATE_DIR=.runtime_state
